const vec2 range_y = vec2(0.0, 1.0);

float scale_y(float value) {
    int slot = 0;
    vec2 domain = vec2(uDomain_y[slot], uDomain_y[slot + 1]);
    float transformed = scaleLinear(value, domain, range_y);
    return transformed;

}

float getScaled_y() {
return scale_y(accessor_y_0());
}

