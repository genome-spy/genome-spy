    int slot = 0;
    vec2 domain = vec2(uDomain_x[slot], uDomain_x[slot + 1]);
    float transformed = scaleLinear(value, domain, range_x);
    return transformed;

}

float getScaled_x() {
return scale_x(accessor_x_0());
