{
  "description": "Two-row theme comparison: rect-bar and scatter (point) views, GenomeSpy defaults vs Vega-Lite-like defaults.",
  "spacing": 24,
  "resolve": {
    "axis": {
      "x": "independent",
      "y": "independent"
    },
    "scale": {
      "color": "independent",
      "x": "independent",
      "y": "independent"
    }
  },
  "vconcat": [
    {
      "data": {
        "values": [
          { "category": "A", "value": 28 },
