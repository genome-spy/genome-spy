{
  "description": "Imported specs can carry self-contained config.",
  "templates": {
    "track": {
      "config": {
        "mark": {
          "color": "#2ca02c"
        },
        "point": {
          "size": 80
        }
      },
      "data": {
        "values": [
          { "x": 1, "y": 2.1 },
          { "x": 2, "y": 1.3 },
          { "x": 3, "y": 2.7 },
          { "x": 4, "y": 2.0 }
        ]
      },
      "mark": "point",
      "encoding": {
        "x": { "field": "x", "type": "quantitative" },
        "y": { "field": "y", "type": "quantitative" }
      }
    }
  },
  "vconcat": [
    { "import": { "template": "track" }, "name": "track-a" },
    { "import": { "template": "track" }, "name": "track-b" }
  ]
}
