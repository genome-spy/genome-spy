# Copy to .env and fill in values.
# .env is gitignored — never commit real tokens or local paths.

# Evo2 model variant to load. Options: evo2_7b, evo2_40b
EVO2_MODEL_NAME=evo2_7b

# Port the server listens on.
EVO2_PORT=8001

# HuggingFace token for downloading model weights (required on first run).
HF_TOKEN=hf_...

# Optional: path to a reference genome FASTA on the host (must have a .fai index).
# Enables coordinate mode in the score endpoint. Most deployments omit this —
# clients are expected to supply sequences directly.
# REF_GENOME_PATH=/path/to/genome.fa
