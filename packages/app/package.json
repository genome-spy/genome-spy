{
  "name": "@genome-spy/app",
  "description": "GenomeSpy-based visualization tool for analyzing multiple biological samples.",
  "author": {
    "name": "Kari Lavikka",
    "email": "kari.lavikka@helsinki.fi"
  },
  "contributors": [],
  "license": "MIT",
  "homepage": "https://genomespy.app/",
  "version": "0.75.0",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "import": "./dist/index.es.js",
      "default": "./dist/index.js"
    },
    "./schema.json": "./dist/schema.json",
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "github:genome-spy/genome-spy",
    "directory": "packages/app"
  },
  "scripts": {
    "dev": "node dev-server.mjs",
    "generate:agent-catalog": "node scripts/generateAgentActionCatalog.mjs",
    "generate:agent-action-types": "node scripts/generateAgentActionTypes.mjs",
    "generate:agent-schema": "node scripts/generateAgentActionSchema.mjs",
    "generate:agent-action-summaries": "node scripts/generateAgentActionSummaries.mjs",
    "check:agent-catalog": "node scripts/checkGeneratedAgentActionCatalog.mjs",
    "check:agent-action-types": "node scripts/checkGeneratedAgentActionTypes.mjs",
    "check:agent-schema": "node scripts/checkGeneratedAgentActionSchema.mjs",
    "check:agent-action-summaries": "node scripts/checkGeneratedAgentActionSummaries.mjs",
    "prebuild": "npm run generate:agent-catalog && npm run generate:agent-action-types && npm run generate:agent-schema && npm run generate:agent-action-summaries",
    "build": "rm -rf dist && mkdir -p dist && vite build && npm run build:schema",
    "build:schema": "mkdir -p dist && ts-json-schema-generator --path 'src/spec/*.d.ts' --type AppRootSpec > dist/schema.json",
    "test:tsc": "npm run test:tsc:src && npm run test:tsc:tests",
    "test:tsc:src": "tsc -p tsconfig.json --noEmit",
    "test:tsc:tests": "tsc -p tsconfig.tests.json --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.1",
    "@fortawesome/fontawesome-free": "^6.4.2",
    "@fortawesome/fontawesome-svg-core": "^6.4.2",
    "@fortawesome/free-solid-svg-icons": "^6.4.2",
    "@genome-spy/core": "^0.75.0",
    "@reduxjs/toolkit": "^2.11.0",
    "ajv": "^8.18.0",
    "d3-color": "^3.1.0",
    "idb": "^7.1.1",
    "lit": "^3.3.0",
    "lz-string": "^1.4.4",
    "mapsort": "^1.0.5",
    "micromark": "^4.0.0",
    "redux-undo": "^1.0.1",
    "zarrita": "^0.6.1"
  }
}
