        }
      },
      "required": [
        "expandViewNode",
        "collapseViewNode",
        "setViewVisibility",
        "jumpToProvenanceState",
        "jumpToInitialProvenanceState",
        "buildSelectionAggregationAttribute",
        "getMetadataAttributeSummary",
        "getGroupedMetadataAttributeSummary",
        "searchViewDatums",
        "submitIntentActions"
      ],
      "type": "object"
    },
    "AggregationOp": {
      "description": "Aggregation operators supported by interval-based attribute access.",
      "enum": ["min", "max", "weightedMean", "variance", "count"],
      "type": "string"
    },
    "BuildSelectionAggregationAttributeToolInput": {
      "additionalProperties": false,
      "description": "Build an `AttributeIdentifier` for a selection-derived aggregation so it can be used in a later intent action. Before using this tool, you must make an interval selection using a parameter or ensure that one already exists. This tool does not compute or return an aggregated value. Use the `submitIntentActions` tool after using this tool. If the requested locus or interval is not the current selection, update the selection first.",
      "examples": [
        {
          "aggregation": "max",
          "candidateId": "brush@foo:bar"
        }
      ],
      "properties": {
        "aggregation": {
          "$ref": "#/definitions/AggregationOp",
          "description": "Aggregation op to apply to the candidate field."
        },
        "candidateId": {
          "description": "Stable identifier for the selected candidate row. The identifiers are available in `selectionAggregationCandidates` in the view context. They become available after a selection is made with a successful `paramChange` action.",
          "type": "string"
        }
      },
      "required": ["candidateId", "aggregation"],
      "type": "object"
    },
    "CollapseViewNodeToolInput": {
      "additionalProperties": false,
      "description": "Collapse a previously expanded view branch in the agent context.",
      "examples": [
        {
          "selector": {
            "scope": [],
            "view": "track"
          }
        }
      ],
      "properties": {
        "selector": {
          "$ref": "#/definitions/ViewSelector",
          "description": "Stable selector for the view node to collapse."
        }
      },
      "required": ["selector"],
      "type": "object"
    },
    "ExpandViewNodeToolInput": {
      "additionalProperties": false,
      "description": "Expand a collapsed view branch in the agent context. The result is only visible in the context and not observable by the user.",
      "examples": [
        {
          "selector": {
            "scope": [],
            "view": "track"
          }
        }
      ],
      "properties": {
        "selector": {
          "$ref": "#/definitions/ViewSelector",
          "description": "Stable selector for the collapsed view node to expand."
        }
      },
      "required": ["selector"],
      "type": "object"
    },
    "GetGroupedMetadataAttributeSummaryToolInput": {
      "additionalProperties": false,
      "description": "Return grouped summaries for one metadata attribute using the current visible grouping hierarchy.",
      "examples": [
        {
          "attribute": {
            "specifier": "tissue",
            "type": "SAMPLE_ATTRIBUTE"
          }
        }
      ],
      "properties": {
        "attribute": {
          "$ref": "#/definitions/SampleAttributeIdentifier",
          "description": "Stable attributeIdentifier for the metadata attribute to summarize by visible groups. In v0, this must be a `SAMPLE_ATTRIBUTE` identifier from the current context."
        }
      },
      "required": ["attribute"],
      "type": "object"
    },
    "GetMetadataAttributeSummaryToolInput": {
      "additionalProperties": false,
      "description": "Return a compact summary of one metadata attribute's current values. Use this when the agent needs factual grounding about which category values exist or what numeric range is present in current sample metadata.",
      "examples": [
        {
          "attribute": {
            "specifier": "sex",
            "type": "SAMPLE_ATTRIBUTE"
          }
        }
      ],
      "properties": {
        "attribute": {
          "$ref": "#/definitions/SampleAttributeIdentifier",
          "description": "Stable attributeIdentifier for the metadata attribute to summarize. In v0, this must be a `SAMPLE_ATTRIBUTE` identifier from the current context."
        }
      },
      "required": ["attribute"],
      "type": "object"
    },
    "JumpToInitialProvenanceStateToolInput": {
      "additionalProperties": {
        "not": {}
      },
      "description": "Jump to the initial provenance state before any actions were dispatched.",
      "type": "object"
    },
    "JumpToProvenanceStateToolInput": {
      "additionalProperties": false,
      "description": "Jump to a prior provenance state identified by the given provenance id. Consult provenance history first when a request should continue from an earlier analysis state, even if the user did not explicitly ask to jump back.",
      "examples": [
        {
          "provenanceId": "provenance-12"
        }
      ],
      "properties": {
        "provenanceId": {
          "description": "Provenance id to jump to.",
          "type": "string"
        }
      },
      "required": ["provenanceId"],
      "type": "object"
    },
    "SampleAttributeIdentifier": {
      "additionalProperties": false,
      "properties": {
        "specifier": {
          "type": "string"
        },
        "type": {
          "const": "SAMPLE_ATTRIBUTE",
          "type": "string"
        }
      },
      "required": ["type", "specifier"],
      "type": "object"
    },
    "SearchViewDatumsToolInput": {
      "additionalProperties": false,
      "description": "Search datum objects in one specific searchable view.",
      "examples": [
        {
          "field": "",
          "mode": "exact",
          "query": "TP53",
          "selector": {
            "scope": [],
            "view": "gene-track"
          }
        }
      ],
      "properties": {
        "field": {
          "description": "Search field name. Use an empty string to search all configured fields.",
          "type": "string"
        },
        "mode": {
          "description": "Search mode. `exact` matches the whole field value. `prefix` matches the beginning of the field value.",
          "enum": ["exact", "prefix"],
          "type": "string"
        },
        "query": {
          "description": "Search term to match against the view's configured search fields.",
          "type": "string"
        },
        "selector": {
          "$ref": "#/definitions/ViewSelector",
          "description": "Stable selector for the searchable view to inspect."
        }
      },
      "required": ["selector", "query", "field", "mode"],
      "type": "object"
    },
    "SetViewVisibilityToolInput": {
      "additionalProperties": false,
      "description": "Set the visibility of a view. This is a user-facing change that will be reflected in the UI.",
      "examples": [
        {
          "selector": {
            "scope": [],
            "view": "reference-sequence"
          },
          "visibility": false
        }
      ],
      "properties": {
        "selector": {
          "$ref": "#/definitions/ViewSelector",
          "description": "Stable selector for the view whose visibility should change."
        },
        "visibility": {
          "description": "Whether the view should be visible.",
          "type": "boolean"
        }
      },
      "required": ["selector", "visibility"],
      "type": "object"
    },
    "SubmitIntentActionsToolInput": {
      "additionalProperties": false,
      "description": "Execute one or more provenance-changing actions. Actions are additive. Before submitting new actions, always consult the current provenance state that defines the state of the analysis. Jump to a prior provenance state if necessary to continue from an earlier point in the analysis. In addition, before constructing the action list, ensure that every `attribute` (AttributeIdentifier) is presented to you in the context or tool results. If not, submit actions one by one and consult the updated context after each action, instead of submitting them all at once.",
      "examples": [
        {
          "actions": [
            {
              "actionType": "sampleView/groupToQuartiles",
              "payload": {
                "attribute": {
                  "specifier": "age",
                  "type": "SAMPLE_ATTRIBUTE"
                }
              }
            }
          ],
          "note": "Group the cohort by quartiles."
        }
      ],
      "properties": {
        "actions": {
          "description": "Ordered actions to execute.",
          "items": {
            "$ref": "#/definitions/AgentIntentBatchStep"
          },
          "minItems": 1,
          "type": "array"
        },
        "note": {
          "description": "Optional short note about the intended change.",
          "type": "string"
        }
      },
      "required": ["actions"],
      "type": "object"
    },
    "ViewSelector": {
      "additionalProperties": false,
      "properties": {
        "scope": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "view": {
          "type": "string"
        }
      },
      "required": ["scope", "view"],
      "type": "object"
    }
  }
}
