{
  "$ref": "#/definitions/AgentIntentProgram",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AgentIntentProgram": {
      "additionalProperties": false,
      "properties": {
        "needsConfirmation": {
          "type": "boolean"
        },
        "rationale": {
          "type": "string"
        },
        "schemaVersion": {
          "const": 1,
          "type": "number"
        },
        "steps": {
          "items": {
            "$ref": "#/definitions/AgentIntentProgramStep"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": ["schemaVersion", "steps"],
      "type": "object"
    },
    "AgentIntentProgramStep": {
      "anyOf": [
        {
          "additionalProperties": false,
          "properties": {
            "actionType": {
              "const": "sortBy",
              "type": "string"
            },
            "payload": {
              "$ref": "#/definitions/SortBy"
            }
          },
          "required": ["actionType", "payload"],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "actionType": {
              "const": "filterByNominal",
              "type": "string"
            },
            "payload": {
              "$ref": "#/definitions/FilterByNominal"
            }
          },
          "required": ["actionType", "payload"],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "actionType": {
              "const": "filterByQuantitative",
              "type": "string"
            },
            "payload": {
              "$ref": "#/definitions/FilterByQuantitative"
            }
          },
          "required": ["actionType", "payload"],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "actionType": {
              "const": "groupByNominal",
              "type": "string"
            },
            "payload": {
              "$ref": "#/definitions/GroupByNominal"
            }
          },
          "required": ["actionType", "payload"],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "actionType": {
              "const": "groupToQuartiles",
              "type": "string"
            },
            "payload": {
              "$ref": "#/definitions/GroupToQuartiles"
            }
          },
          "required": ["actionType", "payload"],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "actionType": {
              "const": "groupByThresholds",
              "type": "string"
            },
            "payload": {
              "$ref": "#/definitions/GroupByThresholds"
            }
          },
          "required": ["actionType", "payload"],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "actionType": {
              "const": "retainFirstNCategories",
              "type": "string"
            },
            "payload": {
              "$ref": "#/definitions/RetainFirstNCategories"
            }
          },
          "required": ["actionType", "payload"],
          "type": "object"
        }
      ]
    },
    "AggregationOp": {
      "description": "Aggregation operators supported by interval-based attribute access.",
      "enum": ["min", "max", "weightedMean", "variance", "count"],
      "type": "string"
    },
    "AggregationSpec": {
      "additionalProperties": false,
      "description": "Aggregation configuration for interval-derived attribute access.",
      "properties": {
        "op": {
          "$ref": "#/definitions/AggregationOp"
        }
      },
      "required": ["op"],
      "type": "object"
    },
    "AttributeIdentifier": {
      "additionalProperties": false,
      "properties": {
        "specifier": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/ViewAttributeSpecifier"
            }
          ]
        },
        "type": {
          "$ref": "#/definitions/AttributeIdentifierType"
        }
      },
      "required": ["type"],
      "type": "object"
    },
    "AttributeIdentifierType": {
      "description": "Stable identifier for an abstract attribute used by actions and agent context.\n\n`type` identifies the attribute source kind, and `specifier` contains the concrete lookup information for that source.\n\nExamples:\n- `{ type: \"SAMPLE_ATTRIBUTE\", specifier: \"age\" }`\n- `{ type: \"VALUE_AT_LOCUS\", specifier: { ... } }`",
      "enum": [
        "SAMPLE_ATTRIBUTE",
        "VALUE_AT_LOCUS",
        "SAMPLE_NAME",
        "VIEW_ATTRIBUTE"
      ],
      "type": "string"
    },
    "ChromosomalLocus": {
      "additionalProperties": false,
      "properties": {
        "chrom": {
          "description": "The name of the chromosome. For example: `\"chr1\"`, `\"CHR1\"`, or `\"1\"`.",
          "type": "string"
        },
        "pos": {
          "description": "The zero-based position inside the chromosome or contig.",
          "type": "number"
        }
      },
      "required": ["chrom"],
      "type": "object"
    },
    "ComparisonOperatorType": {
      "enum": ["lt", "lte", "eq", "gte", "gt"],
      "type": "string"
    },
    "ComplexDomain": {
      "description": "A complex domain that needs to be converted into a scalar domain before it is assigned to a scale.",
      "items": {
        "$ref": "#/definitions/ChromosomalLocus"
      },
      "type": "array"
    },
    "FilterByNominal": {
      "additionalProperties": false,
      "properties": {
        "attribute": {
          "$ref": "#/definitions/AttributeIdentifier",
          "description": "Attribute identifier used by the action."
        },
        "remove": {
          "description": "If true, matching samples are removed instead of retained.",
          "type": "boolean"
        },
        "values": {
          "description": "Discrete values to match.",
          "items": {},
          "type": "array"
        }
      },
      "required": ["attribute", "values"],
      "type": "object"
    },
    "FilterByQuantitative": {
      "additionalProperties": false,
      "description": "Payload for filtering samples by comparing a quantitative attribute against a numeric operand.",
      "properties": {
        "attribute": {
          "$ref": "#/definitions/AttributeIdentifier",
          "description": "Attribute identifier used by the action."
        },
        "operand": {
          "description": "Numeric threshold used in the comparison.",
          "type": "number"
        },
        "operator": {
          "$ref": "#/definitions/ComparisonOperatorType",
          "description": "Comparison operator used for thresholding."
        }
      },
      "required": ["attribute", "operand", "operator"],
      "type": "object"
    },
    "GroupByNominal": {
      "additionalProperties": false,
      "description": "Payload for grouping by a categorical attribute.",
      "properties": {
        "attribute": {
          "$ref": "#/definitions/AttributeIdentifier",
          "description": "Attribute identifier used by the action."
        }
      },
      "required": ["attribute"],
      "type": "object"
    },
    "GroupByThresholds": {
      "additionalProperties": false,
      "properties": {
        "attribute": {
          "$ref": "#/definitions/AttributeIdentifier",
          "description": "Attribute identifier used by the action."
        },
        "thresholds": {
          "description": "Thresholds used to stratify the samples.",
          "items": {
            "$ref": "#/definitions/Threshold"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": ["attribute", "thresholds"],
      "type": "object"
    },
    "GroupToQuartiles": {
      "additionalProperties": false,
      "description": "Payload for grouping by quartiles.",
      "properties": {
        "attribute": {
          "$ref": "#/definitions/AttributeIdentifier",
          "description": "Attribute identifier used by the action."
        }
      },
      "required": ["attribute"],
      "type": "object"
    },
    "Interval": {
      "description": "Interval expressed as two scalar or locus points.",
      "items": {
        "$ref": "#/definitions/IntervalPoint"
      },
      "maxItems": 2,
      "minItems": 2,
      "type": "array"
    },
    "IntervalPoint": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "$ref": "#/definitions/ChromosomalLocus"
        }
      ],
      "description": "One endpoint of an interval."
    },
    "IntervalReference": {
      "anyOf": [
        {
          "$ref": "#/definitions/Interval"
        },
        {
          "$ref": "#/definitions/SelectionIntervalSource"
        }
      ],
      "description": "Literal interval or selection-backed interval reference."
    },
    "IntervalSpecifier": {
      "additionalProperties": false,
      "description": "Specifier that summarizes a field over an interval.",
      "properties": {
        "aggregation": {
          "$ref": "#/definitions/AggregationSpec",
          "description": "Aggregation operation to apply over the interval"
        },
        "domainAtActionTime": {
          "anyOf": [
            {
              "$ref": "#/definitions/NumericDomain"
            },
            {
              "$ref": "#/definitions/ComplexDomain"
            }
          ],
          "description": "The x-scale domain that was visible when the action was triggered."
        },
        "field": {
          "description": "Attribute or field name used by the specifier.",
          "type": "string"
        },
        "interval": {
          "$ref": "#/definitions/IntervalReference",
          "description": "Literal interval or a selection source resolved at action execution time"
        },
        "view": {
          "$ref": "#/definitions/ViewRef",
          "description": "A unique view reference. Legacy values may be a view name string."
        }
      },
      "required": ["aggregation", "field", "interval", "view"],
      "type": "object"
    },
    "LocusSpecifier": {
      "additionalProperties": false,
      "description": "Specifier that points to a single locus or scalar coordinate.",
      "properties": {
        "domainAtActionTime": {
          "anyOf": [
            {
              "$ref": "#/definitions/NumericDomain"
            },
            {
              "$ref": "#/definitions/ComplexDomain"
            }
          ],
          "description": "The x-scale domain that was visible when the action was triggered."
        },
        "field": {
          "description": "Attribute or field name used by the specifier.",
          "type": "string"
        },
        "locus": {
          "anyOf": [
            {
              "$ref": "#/definitions/Scalar"
            },
            {
              "$ref": "#/definitions/ChromosomalLocus"
            }
          ],
          "description": "Coordinate on the `x` axis. May be a number of locus on a chromosome. Alternatively, a scalar if a categorical scale is used."
        },
        "view": {
          "$ref": "#/definitions/ViewRef",
          "description": "A unique view reference. Legacy values may be a view name string."
        }
      },
      "required": ["field", "locus", "view"],
      "type": "object"
    },
    "NumericDomain": {
      "items": {
        "type": "number"
      },
      "type": "array"
    },
    "ParamSelector": {
      "additionalProperties": false,
      "description": "Structured parameter address used for bookmarkable selections and values.",
      "properties": {
        "param": {
          "type": "string"
        },
        "scope": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": ["scope", "param"],
      "type": "object"
    },
    "RetainFirstNCategories": {
      "additionalProperties": false,
      "properties": {
        "attribute": {
          "$ref": "#/definitions/AttributeIdentifier",
          "description": "Attribute identifier used by the action."
        },
        "n": {
          "description": "Number of categories to retain.",
          "minimum": 1,
          "type": "number"
        }
      },
      "required": ["attribute", "n"],
      "type": "object"
    },
    "Scalar": {
      "type": ["string", "number", "boolean"]
    },
    "SelectionIntervalSource": {
      "additionalProperties": false,
      "description": "Interval that will be resolved from a selection parameter.",
      "properties": {
        "selector": {
          "$ref": "#/definitions/ParamSelector"
        },
        "type": {
          "const": "selection",
          "type": "string"
        }
      },
      "required": ["type", "selector"],
      "type": "object"
    },
    "SortBy": {
      "additionalProperties": false,
      "description": "Payload for sorting samples by an attribute.",
      "properties": {
        "attribute": {
          "$ref": "#/definitions/AttributeIdentifier",
          "description": "Attribute identifier used by the action."
        }
      },
      "required": ["attribute"],
      "type": "object"
    },
    "Threshold": {
      "additionalProperties": false,
      "description": "Numeric threshold used when partitioning or filtering quantitative values.",
      "properties": {
        "operand": {
          "description": "Numeric threshold value.",
          "type": "number"
        },
        "operator": {
          "$ref": "#/definitions/ThresholdOperator",
          "description": "Threshold side to use when creating groups."
        }
      },
      "required": ["operator", "operand"],
      "type": "object"
    },
    "ThresholdOperator": {
      "enum": ["lt", "lte"],
      "type": "string"
    },
    "ViewAttributeSpecifier": {
      "anyOf": [
        {
          "$ref": "#/definitions/LocusSpecifier"
        },
        {
          "$ref": "#/definitions/IntervalSpecifier"
        }
      ],
      "description": "Supported view-backed attribute specifiers used by the sample collection actions."
    },
    "ViewRef": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "$ref": "#/definitions/ViewSelector"
        }
      ],
      "description": "View reference used in SampleView actions. Legacy values may be a view name string, but selectors are the unambiguous, bookmark-friendly form."
    },
    "ViewSelector": {
      "additionalProperties": false,
      "description": "Structured view address used by selectors.\n\nThe selector identifies a view by its import scope and name, which makes it stable for provenance and replay.",
      "properties": {
        "scope": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "view": {
          "type": "string"
        }
      },
      "required": ["scope", "view"],
      "type": "object"
    }
  }
}
