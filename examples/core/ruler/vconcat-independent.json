{
  "$schema": "https://unpkg.com/@genome-spy/core/dist/schema.json",

  "description": "A parent ruler is rendered separately in each vconcat child.",

  "params": [
    {
      "name": "cursor",
      "persist": false,
      "ruler": {
        "encodings": ["x"],
        "on": "mousemove",
        "extent": "view",
        "mark": { "stroke": "black", "strokeDash": [4, 2] }
      }
    }
  ],

  "resolve": {
    "scale": { "x": "shared" }
  },

  "vconcat": [
    {
      "data": {
        "values": [
          { "x": 1, "y": 2 },
          { "x": 2, "y": 5 },
          { "x": 3, "y": 3 },
          { "x": 4, "y": 8 }
        ]
      },
      "mark": "point",
      "encoding": {
        "x": { "field": "x", "type": "quantitative" },
        "y": { "field": "y", "type": "quantitative" }
      }
    },

    {
      "data": {
        "values": [
          { "x": 1, "y": 9 },
          { "x": 2, "y": 4 },
          { "x": 3, "y": 6 },
          { "x": 4, "y": 2 }
        ]
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative" },
        "y": { "field": "y", "type": "quantitative" }
      },
      "layer": [
        {
          "mark": { "type": "point", "size": 180, "opacity": 0.25 }
        },
        {
          "mark": { "type": "point", "size": 40, "filled": true }
        }
      ]
    }
  ]
}
