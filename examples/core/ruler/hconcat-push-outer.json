{
  "$schema": "https://unpkg.com/@genome-spy/core/dist/schema.json",

  "description": "A child ruler pushes a coordinate to an outer parameter used by a sibling view.",

  "params": [{ "name": "cursor", "persist": false }],

  "resolve": {
    "scale": { "y": "independent" }
  },

  "hconcat": [
    {
      "data": {
        "values": [
          { "x": 1, "y": 2 },
          { "x": 2, "y": 4 },
          { "x": 3, "y": 3 },
          { "x": 4, "y": 7 },
          { "x": 5, "y": 5 }
        ]
      },
      "params": [
        {
          "name": "cursor",
          "push": "outer",
          "ruler": {
            "encodings": ["x"],
            "on": "mousemove",
            "extent": "view"
          }
        }
      ],
      "mark": "point",
      "encoding": {
        "x": { "field": "x", "type": "quantitative" },
        "y": { "field": "y", "type": "quantitative" }
      }
    },

    {
      "data": { "values": [{}] },
      "transform": [],
      "mark": "text",
      "encoding": {
        "text": { "expr": "'' + cursor.values.x" }
      }
    }
  ]
}
