{
  "$schema": "https://unpkg.com/@genome-spy/core/dist/schema.json",

  "description": "A child ruler pushes a coordinate to an outer parameter used by a sibling view.",

  "params": [{ "name": "cursor", "persist": false }],

  "resolve": {
    "scale": { "y": "independent" }
  },

  "hconcat": [
    {
      "data": {
        "values": [
          { "x": 1, "y": 2 },
          { "x": 2, "y": 4 },
          { "x": 3, "y": 3 },
          { "x": 4, "y": 7 },
          { "x": 5, "y": 5 }
        ]
      },
      "params": [
        {
          "name": "cursor",
          "push": "outer",
          "ruler": {
            "encodings": ["x"],
            "on": "mousemove",
            "extent": "view"
          }
        }
      ],
      "mark": "point",
      "encoding": {
        "x": { "field": "x", "type": "quantitative" },
        "y": { "field": "y", "type": "quantitative" }
      }
    },

    {
      "data": {
        "values": [
          { "start": 0.5, "end": 1.5, "row": 1 },
          { "start": 1.5, "end": 2.5, "row": 2 },
          { "start": 2.5, "end": 3.5, "row": 3 },
          { "start": 3.5, "end": 4.5, "row": 4 },
          { "start": 4.5, "end": 5.5, "row": 5 }
        ]
      },
      "transform": [
        {
          "type": "filter",
          "expr": "cursor.type === 'ruler' && cursor.values.x != null && datum.start <= cursor.values.x && cursor.values.x < datum.end"
        }
      ],
      "mark": "point",
      "encoding": {
        "x": { "field": "start", "type": "quantitative" },
        "y": { "field": "row", "type": "quantitative" }
      }
    }
  ]
}
