{
  "$schema": "https://unpkg.com/@genome-spy/core/dist/schema.json",

  "description": "Legend test case for a logarithmic color scale.",

  "width": 360,
  "height": 240,

  "config": { "legend": { "disable": false, "padding": 18 } },

  "data": {
    "sequence": { "start": 0, "stop": 241, "step": 1, "as": "x" }
  },

  "transform": [
    {
      "type": "formula",
      "expr": "pow(10, datum.x / 60)",
      "as": "value"
    }
  ],

  "mark": { "type": "point", "filled": true, "opacity": 0.75, "size": 24 },

  "encoding": {
    "x": {
      "field": "x",
      "type": "quantitative",
      "title": "Continuous x"
    },
    "y": {
      "field": "value",
      "type": "quantitative",
      "title": "Log y",
      "scale": { "type": "log", "domain": [1, 10000], "zero": false }
    },
    "color": {
      "field": "value",
      "type": "quantitative",
      "title": "Log color",
      "scale": { "type": "log", "domain": [1, 10000], "zero": false },
      "legend": { "title": "Log" }
    }
  }
}
