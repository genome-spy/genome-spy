{
  "$schema": "https://unpkg.com/@genome-spy/core/dist/schema.json",

  "genome": { "name": "hg38" },

  "title": { "text": "GC content", "style": "overlay-title" },

  "config": {
    "legend": { "disable": false, "offset": 18 },
    "view": { "stroke": "lightgray" }
  },

  "data": {
    "lazy": {
      "type": "bigwig",
      "url": "https://data.genomespy.app/genomes/hg38/hg38.gc5Base.bw",
      "pixelsPerBin": 1
    }
  },

  "transform": [{ "type": "filter", "expr": "datum.score > 0" }],

  "encoding": {
    "x": { "chrom": "chrom", "pos": "start", "type": "locus" },
    "x2": { "chrom": "chrom", "pos": "end" }
  },

  "resolve": {
    "axis": { "x": "shared" },
    "legend": { "color": "shared" }
  },

  "vconcat": [
    {
      "height": 140,
      "encoding": {
        "x": { "chrom": "chrom", "pos": "start", "type": "locus" },
        "y": {
          "field": "score",
          "type": "quantitative",
          "scale": { "nice": true, "zero": false, "clamp": true },
          "axis": {
            "title": "GC (%)",
            "grid": true,
            "gridDash": [2, 2],
            "maxExtent": 35
          }
        }
      },
      "mark": {
        "type": "rect",
        "minWidth": 0.5,
        "minOpacity": 1,
        "tooltip": null
      }
    },
    {
      "height": 80,
      "encoding": {
        "color": {
          "field": "score",
          "type": "quantitative",
          "scale": { "zero": false },
          "legend": { "title": "GC (%)" }
        }
      },
      "mark": {
        "type": "rect",
        "minWidth": 0.5,
        "minOpacity": 1,
        "tooltip": null
      }
    }
  ]
}
