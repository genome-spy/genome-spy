{
  "$schema": "https://unpkg.com/@genome-spy/core/dist/schema.json",

  "data": { "url": "data/sincos.csv" },
  "config": {
    "view": {
      "stroke": "lightgray"
    }
  },
  "encoding": {
    "x": { "field": "x", "type": "quantitative" },
    "y": { "field": "sin", "type": "quantitative" }
  },

  "hconcat": [
    {
      "vconcat": [
        {
          "mark": "point"
        },
        {
          "hconcat": [
            {
              "width": 150,
              "mark": "point",
              "encoding": {
                "y": {
                  "field": "sin",
                  "type": "quantitative",
                  "axis": { "offset": 10 }
                }
              }
            },
            {
              "padding": { "top": 30, "left": 20, "right": 20 },
              "title": {
                "text": "Hello!",
                "orient": "top",
                "fontSize": 16,
                "fontWeight": "bold"
              },
              "width": { "grow": 0.5 },
              "mark": "point"
            }
          ]
        }
      ]
    },
    {
      "padding": { "left": 20, "right": 20 },
      "mark": "point"
    }
  ]
}
