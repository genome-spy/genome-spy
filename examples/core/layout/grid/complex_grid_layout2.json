{
  "$schema": "https://unpkg.com/@genome-spy/core/dist/schema.json",

  "data": { "url": "data/sincos.csv" },
  "config": {
    "view": {
      "stroke": "lightgray"
    },
    "axisQuantitative": {
      "grid": true
    }
  },
  "encoding": {
    "y": {
      "field": "sin",
      "type": "quantitative"
    }
  },

  "name": "root",

  "hconcat": [
    {
      "columns": 1,
      "name": "left",
      "resolve": {
        "scale": { "x": "shared" },
        "axis": { "x": "shared" }
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative",
          "axis": {
            "orient": "top"
          }
        }
      },
      "concat": [
        {
          "columns": 1,
          "resolve": {
            "scale": { "x": "shared" },
            "axis": { "x": "shared" }
          },
          "concat": [
            {
              "mark": "point"
            },
            {
              "mark": "point",
              "encoding": {
                "y": {
                  "field": "sin",
                  "type": "quantitative",
                  "axis": { "orient": "right" }
                }
              }
            }
          ]
        },
        {
          "mark": "point"
        }
      ]
    },
    {
      "columns": 1,
      "name": "right",
      "resolve": {
        "scale": { "x": "shared" },
        "axis": { "x": "shared" }
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative",
          "axis": {
            "orient": "bottom"
          }
        }
      },
      "concat": [
        {
          "columns": 1,
          "resolve": {
            "scale": { "x": "shared" },
            "axis": { "x": "shared" }
          },
          "concat": [
            {
              "mark": "point"
            },
            {
              "mark": "point",
              "encoding": {
                "y": {
                  "field": "sin",
                  "type": "quantitative",
                  "axis": { "orient": "right" }
                }
              }
            }
          ]
        },
        {
          "mark": "point"
        }
      ]
    }
  ]
}
