{
  "$schema": "https://unpkg.com/@genome-spy/core/dist/schema.json",

  "description": "Displaying view dimensions.",

  "data": {
    "values": [{}]
  },

  "hconcat": [
    {
      "width": { "grow": 1 },
      "mark": {
        "type": "text",
        "size": 20,
        "text": { "expr": "'' + width + ' x ' + height" }
      }
    },
    {
      "width": { "grow": 2 },
      "mark": {
        "type": "text",
        "size": 20,
        "text": { "expr": "'' + width + ' x ' + height" }
      }
    }
  ],

  "config": {
    "view": { "stroke": "lightgray" }
  }
}
