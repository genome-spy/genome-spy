{
  "$schema": "https://cdn.jsdelivr.net/npm/@genome-spy/core/dist/schema.json",

  "description": "Template import example with repeated named tracks.",

  "vconcat": [
    {
      "import": { "template": "myTrack" },
      "name": "trackA",
      "visible": true,
      "params": [{ "name": "size", "value": 5 }]
    },
    {
      "import": { "template": "myTrack" },
      "name": "trackB",
      "visible": true,
      "params": { "offset": 3.141, "size": 20 }
    }
  ],

  "templates": {
    "myTrack": {
      "params": [
        { "name": "offset", "value": 0 },
        { "name": "size", "value": 10 }
      ],
      "data": {
        "sequence": { "start": 0, "stop": 20, "step": 0.2, "as": "x" }
      },
      "transform": [
        { "type": "formula", "expr": "sin(datum.x + offset)", "as": "y" }
      ],
      "mark": "point",
      "encoding": {
        "size": {
          "value": { "expr": "size" }
        },
        "x": { "field": "x", "type": "quantitative" },
        "y": { "field": "y", "type": "quantitative" }
      }
    }
  }
}
