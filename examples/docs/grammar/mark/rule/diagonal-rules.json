{
  "$schema": "https://cdn.jsdelivr.net/npm/@genome-spy/core/dist/schema.json",
  "description": "Rule mark example with diagonal rules.",
  "width": 300,
  "height": 300,
  "data": {
    "sequence": {
      "start": 0,
      "stop": 50
    }
  },
  "transform": [
    {
      "type": "formula",
      "expr": "random()",
      "as": "x"
    },
    {
      "type": "formula",
      "expr": "datum.x + random() * 0.5 - 0.25",
      "as": "x2"
    },
    {
      "type": "formula",
      "expr": "random()",
      "as": "y"
    },
    {
      "type": "formula",
      "expr": "datum.y + random() * 0.5 - 0.25",
      "as": "y2"
    },
    {
      "type": "formula",
      "expr": "random()",
      "as": "size"
    }
  ],
  "mark": {
    "type": "rule",
    "strokeCap": "round"
  },
  "encoding": {
    "x": {
      "field": "x",
      "type": "quantitative"
    },
    "x2": {
      "field": "x2"
    },
    "y": {
      "field": "y",
      "type": "quantitative"
    },
    "y2": {
      "field": "y2"
    },
    "size": {
      "field": "size",
      "type": "quantitative",
      "scale": {
        "type": "pow",
        "range": [
          0,
          10
        ]
      }
    },
    "color": {
      "field": "x",
      "type": "nominal",
      "scale": {
        "scheme": "category20"
      }
    }
  }
}
