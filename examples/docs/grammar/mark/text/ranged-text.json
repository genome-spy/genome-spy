{
  "$schema": "https://cdn.jsdelivr.net/npm/@genome-spy/core/dist/schema.json",

  "description": "Text mark example positioned inside ranges.",

  "data": { "values": ["A", "B", "C", "D", "E", "F", "G"] },

  "transform": [
    { "type": "formula", "expr": "round(random() * 100)", "as": "a" },
    { "type": "formula", "expr": "datum.a + round(random() * 60)", "as": "b" }
  ],

  "encoding": {
    "x": {
      "field": "a",
      "type": "quantitative",
      "scale": { "zoom": true }
    },
    "x2": { "field": "b" },
    "y": {
      "field": "data",
      "type": "nominal",
      "scale": { "padding": 0.3 }
    }
  },

  "layer": [
    {
      "mark": "rect",
      "encoding": {
        "color": { "value": "#eaeaea" }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "paddingX": 5
      },
      "encoding": {
        "text": { "expr": "'Hello ' + floor(datum.a)" },
        "size": { "value": 12 }
      }
    }
  ]
}
