{
  "$schema": "https://unpkg.com/@genome-spy/core/dist/schema.json",

  "description": "Directional segments rendered with the arrow mark.",

  "data": {
    "values": [
      { "feature": "gene A", "start": 8, "end": 38 },
      { "feature": "gene B", "start": 44, "end": 92 }
    ]
  },

  "mark": {
    "type": "arrow",
    "size": 18,
    "headWidth": 2,
    "fill": "#5B8DEF",
    "stroke": "black",
    "strokeWidth": 1
  },

  "encoding": {
    "x": {
      "field": "start",
      "type": "index",
      "scale": { "domain": [0, 100] },
      "axis": { "title": "Position" }
    },
    "x2": { "field": "end" },
    "y": {
      "field": "feature",
      "type": "nominal",
      "scale": { "type": "band", "padding": 0.25 },
      "axis": { "title": null }
    }
  }
}
