{
  "$schema": "https://cdn.jsdelivr.net/npm/@genome-spy/core/dist/schema.json",
  "description": "Tick mark example.",

  "data": { "url": "vega-datasets/cars.json" },
  "mark": "tick",
  "encoding": {
    "x": { "field": "Horsepower", "type": "quantitative" },
    "y": {
      "field": "Cylinders",
      "type": "ordinal",
      "scale": { "padding": 0.25 }
    }
  }
}
