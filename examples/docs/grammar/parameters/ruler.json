{
  "$schema": "https://cdn.jsdelivr.net/npm/@genome-spy/core/dist/schema.json",

  "description": "Ruler parameter example.",

  "params": [
    {
      "name": "cursor",
      "persist": false,
      "ruler": {
        "encodings": ["x"],
        "mark": { "stroke": "red" }
      }
    }
  ],

  "data": {
    "values": [
      { "x": 10, "x2": 40, "y": 1 },
      { "x": 50, "x2": 90, "y": 1 },
      { "x": 30, "x2": 70, "y": 2 }
    ]
  },

  "encoding": {
    "x": { "field": "x", "type": "index", "scale": { "domain": [0, 100] } },
    "x2": { "field": "x2" },
    "y": { "field": "y", "type": "ordinal" }
  },

  "resolve": { "scale": { "x": "independent" } },

  "vconcat": [
    { "mark": "rect", "title": "Move your mouse over the plot!" },
    { "mark": "rect" }
  ],

  "config": {
    "view": { "stroke": "lightgray" },
    "scale": { "ordinal": { "padding": 0.2 } }
  }
}
