{
  "$schema": "https://cdn.jsdelivr.net/npm/@genome-spy/core/dist/schema.json",

  "description": "BEDPE example using link marks between paired breakpoints.",

  "assembly": "hg38",

  "data": {
    "url": "data/events.bedpe",
    "format": { "type": "bedpe" }
  },

  "mark": {
    "type": "link",
    "linkShape": "dome",
    "orient": "vertical",
    "clampApex": true
  },

  "encoding": {
    "x": { "chrom": "chrom1", "pos": "start1", "type": "locus" },
    "x2": { "chrom": "chrom2", "pos": "start2" },
    "y": { "field": "score", "type": "quantitative" },
    "size": { "value": 2 },
    "color": { "field": "name", "type": "nominal" }
  }
}
